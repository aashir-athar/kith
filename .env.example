# Point the app at your Kith relay to turn on the real end-to-end backend. Copy this to a `.env`
# (git-ignored) or set it in your EAS build profile. Without it the app runs the local mock,
# which is a design/demo mode only and is compiled out of release builds.
#
#   real device        -> http://<your-lan-ip>:8787
#   Android emulator   -> http://10.0.2.2:8787
#   iOS simulator      -> http://localhost:8787
EXPO_PUBLIC_API_URL=http://localhost:8787
