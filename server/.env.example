# Copy to .env for local dev outside Docker. Inside docker-compose these are set for you.
PORT=8787
DATABASE_URL=postgres://kith:kith@localhost:5432/kith
REDIS_URL=redis://localhost:6379
NODE_ENV=development
# Rotate in production. Signs opaque session ids stored in Redis.
SESSION_SECRET=dev-only-change-me
# Browser origins allowed to call the relay (comma-separated). The web client dev server is :3000.
CORS_ORIGIN=http://localhost:3000
